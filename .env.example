# ============================================================
# QuickQuo — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=QuickQuo

# In production set to:
# NEXT_PUBLIC_APP_URL=https://quickquo.co.uk

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key — server-side ONLY, never expose to client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Used for CLI type generation (dev only)
SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# ── Resend (transactional email) ─────────────────────────────
# Found in: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Verified sender: use your Resend subdomain (e.g. you@your-subdomain.resend.app)
# Format: "Display Name <email@domain.com>" or email@domain.com
RESEND_FROM_EMAIL=QuickQuo <waitlist@treniechue.resend.app>

# ── Notifications ────────────────────────────────────────────
# Your email — receives a notification on every new waitlist signup
OWNER_EMAIL=hello@quickquo.co.uk

# ── Demo URL ─────────────────────────────────────────────────
# The existing QuickQuo beta/demo model URL
NEXT_PUBLIC_DEMO_URL=https://app.quickquo.co.uk/demo

# ── Stripe (for dashboard billing — add when ready) ──────────
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_AGENCY_PRICE_ID=price_...

# ── Twilio (for missed call SMS — add when ready) ─────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+447700000000

# ── OpenAI (for AI quote generation — add when ready) ─────────
# OPENAI_API_KEY=sk-...
